# Atelier environment variables
#
# Everything below is OPTIONAL. With none of it set, the site runs fully:
# the builder is open to everyone and the brief is parsed on-device.

# --- Authentication (Clerk) -------------------------------------------------
# Set BOTH keys to turn on real accounts and gate /builder behind sign-in.
# Get them from https://dashboard.clerk.com  →  API keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- AI brief parsing (Anthropic) -------------------------------------------
# Set this to have the builder parse the design brief with Claude.
# Without it, the brief is parsed on-device. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
