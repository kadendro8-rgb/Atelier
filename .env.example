# Atelier environment variables
#
# Optional. With nothing set, the site runs fully — the builder is open
# to everyone and the design brief is parsed on-device.

# --- AI brief parsing (Anthropic) -------------------------------------------
# Set this to have the builder parse the design brief with Claude.
# Without it, the brief is parsed on-device. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# --- Lead persistence (Supabase) --------------------------------------------
# Injected automatically when the Supabase integration is connected in Vercel.
# The /api/save-brief route writes to the `leads` table using the service-role
# key. Without these set, leads are accepted but not persisted.
# Server-side only — never expose the service-role key to the client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Marketing engine (factory worker E2) -----------------------------------
# The marketing engine (lib/marketing, /api/marketing, scripts/marketing-agent.mjs)
# generates social posts, articles, ads, and SEO/AEO/GEO schema. With nothing
# set it runs fully on deterministic on-brand templates; ANTHROPIC_API_KEY
# above upgrades generation to Claude.
#
# Base URL the CLI calls. Defaults to the local dev server.
MARKETING_API_URL=http://localhost:3000
#
# Live publishing credentials. The publish queue runs in dry-run mode until
# real platform adapters are wired (see docs/factory/E2-marketing.md — this is
# a foreman task). Leave blank to keep the queue in dry-run.
#   Meta (Instagram + Facebook) — Graph API
META_ACCESS_TOKEN=
META_PAGE_ID=
META_IG_USER_ID=
#   X (Twitter) — API v2
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
#   LinkedIn — Marketing API
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=
#   TikTok / Pinterest / YouTube — content posting APIs
TIKTOK_ACCESS_TOKEN=
PINTEREST_ACCESS_TOKEN=
YOUTUBE_API_KEY=
